# === KERNEL-ONLY CONFIGURATION ===
# Only configs not defined in generic/ipq40xx configs or by packages

# === HARDWARE ACCELERATION ===
CONFIG_CRYPTO_DEV_QCE=y
CONFIG_CRYPTO_DEV_QCE_SW_MAX_LEN=1500
CONFIG_IRQBALANCE=y

# === IPQ4019 SPECIFIC ===
CONFIG_ARCH_IPQ40XX=y
CONFIG_PINCTRL_IPQ4019=y
CONFIG_CLK_QCOM_GCC_IPQ4019=y
CONFIG_REGULATOR_IPQ4019=y

# === DSA NETWORKING ===
CONFIG_NET_DSA=y
CONFIG_NET_DSA_TAG_QCA=y
CONFIG_NET_DSA_QCA8K=y

# === MTD FIRMWARE SPLITTING ===
CONFIG_MTD_SPLIT_FIRMWARE=y
CONFIG_MTD_SPLIT_TPLINK_FW=y

# === COMPRESSION OPTIMIZATIONS ===
CONFIG_KERNEL_GZIP=y
CONFIG_RD_GZIP=y
CONFIG_DECOMPRESS_GZIP=y
CONFIG_SQUASHFS_XZ=y
CONFIG_SQUASHFS_XATTR=y
CONFIG_SQUASHFS_FRAGMENT_CACHE_SIZE=1

# === MEMORY OPTIMIZATION ===
CONFIG_ZRAM_DEF_COMP_LZ4=y
CONFIG_LZ4_COMPRESS=y
CONFIG_LZ4_DECOMPRESS=y

# === WIFI MESH SUPPORT ===
CONFIG_MAC80211_MESH=y
CONFIG_CFG80211_WEXT_EXPORT=y

# === LED SUPPORT ===
CONFIG_LEDS_LP55XX_COMMON=y
CONFIG_LEDS_LP5521=y

