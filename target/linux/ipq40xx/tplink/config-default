CONFIG_TARGET_DEFAULT_LAN_IP_FROM_PREINIT=y
CONFIG_TARGET_PREINIT_SHOW_NETMSG=y
CONFIG_USE_FS_ACL_ATTR=y
CONFIG_LEDS_GPIO=y
CONFIG_GPIOLIB=y

# Automated build configuration TODO: add dynamic domain ending 
CONFIG_KERNEL_BUILD_USER="openwrt"
CONFIG_KERNEL_BUILD_DOMAIN="deco-m4-v3"

# Network features for mesh and VLAN
CONFIG_IPV6=y
CONFIG_IPV6_MULTIPLE_TABLES=y
CONFIG_IPV6_SUBTREES=y

# Essential DSA/VLAN support  
CONFIG_NET_DSA=y
CONFIG_BRIDGE_VLAN_FILTERING=y
CONFIG_VLAN_8021Q=y

# Mesh networking
CONFIG_MAC80211_MESH=y
CONFIG_B43_PHY_G=y

# VLAN support
CONFIG_VLAN_8021Q=y
CONFIG_VLAN_8021Q_GVRP=y

# Kernel config 
CONFIG_KERNEL_FS_POSIX_ACL=y
CONFIG_KERNEL_IPV6_SEG6_LWTUNNEL=y
CONFIG_KERNEL_JFFS2_FS_POSIX_ACL=y
CONFIG_KERNEL_JFFS2_FS_SECURITY=y
CONFIG_KERNEL_NET_L3_MASTER_DEV=y
CONFIG_KERNEL_SQUASHFS_FRAGMENT_CACHE_SIZE=1
