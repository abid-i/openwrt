CONFIG_KERNEL_TMPFS_POSIX_ACL=y
CONFIG_KERNEL_KEXEC=y
CONFIG_PACKAGE_kexec-tools=y
CONFIG_KERNEL_ZRAM_BACKEND_LZ4=y
CONFIG_KERNEL_ZRAM_DEF_COMP_LZ4=y
CONFIG_CRYPTO_DEV_QCE_SW_MAX_LEN=1500

# MTD splitting for TP-Link firmware format
CONFIG_MTD_SPLIT_FIRMWARE=y
CONFIG_MTD_SPLIT_TPLINK_FW=y

# Performance optimizations
CONFIG_IRQBALANCE=y
CONFIG_ZRAM_DEF_COMP_LZORLE=y

CONFIG_RD_XZ=y # what is this 
CONFIG_SQUASHFS_XZ=y

# Busybox
CONFIG_BUSYBOX_CUSTOM=y
CONFIG_BUSYBOX_CONFIG_ASH_OPTIMIZE_FOR_SIZE=y
CONFIG_BUSYBOX_CONFIG_BASH_IS_ASH=y
CONFIG_BUSYBOX_CONFIG_FEATURE_UDHCP_8021Q=y
CONFIG_BUSYBOX_CONFIG_FEATURE_VI_UNDO=y
CONFIG_BUSYBOX_CONFIG_FEATURE_VI_UNDO_QUEUE=y
CONFIG_BUSYBOX_CONFIG_FEATURE_VI_UNDO_QUEUE_MAX=32

# Dropbear ssh
