# === CRITICAL SIZE OPTIMIZATIONS ===
CONFIG_CC_OPTIMIZE_FOR_SIZE=y
CONFIG_DEBUG_INFO=n
CONFIG_DEBUG_KERNEL=n
CONFIG_SLUB_DEBUG=n
CONFIG_DEBUG_BUGVERBOSE=n
CONFIG_KALLSYMS=n
CONFIG_PRINTK_TIME=n
CONFIG_DEBUG_MISC=n
CONFIG_BUG_ON_DATA_CORRUPTION=n

# === KERNEL BUILD OPTIMIZATIONS ===
