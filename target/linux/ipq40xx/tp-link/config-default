# OpenWrt kernel config for TP-Link Deco M4 v3 (IPQ4019)
# Optimized for mesh WiFi node with hardware crypto acceleration
# Fixed configuration to prevent interactive prompts

CONFIG_TARGET_ipq40xx=y
CONFIG_TARGET_ipq40xx_generic=y
CONFIG_TARGET_ipq40xx_generic_DEVICE_tp-link_deco-m4r-v2=y
CONFIG_TARGET_BOARD="ipq40xx"
CONFIG_TARGET_SUBTARGET="TP-Link"
CONFIG_TARGET_ARCH_PACKAGES="arm_cortex-a7_neon-vfpv4"
CONFIG_DEFAULT_TARGET_OPTIMIZATION="-Os -pipe"
CONFIG_CPU_TYPE="cortex-a7+neon-vfpv4"

# === ESSENTIAL SYSTEM CONFIG ===
CONFIG_MTD_UBI=y
CONFIG_MTD_UBI_BEB_LIMIT=20
CONFIG_MTD_UBI_BLOCK=y
CONFIG_MTD_UBI_NVMEM=y
CONFIG_MTD_UBI_WL_THRESHOLD=4096
CONFIG_REGULATOR_USERSPACE_CONSUMER=y
CONFIG_UBIFS_FS=y

# === NETWORKING CORE ===
CONFIG_IP_ROUTE_MULTIPATH=y
CONFIG_IP_ROUTE_VERBOSE=y
CONFIG_IPV6_OPTIMISTIC_DAD=y
CONFIG_IPV6_MIP6=y

# === QoS AND TRAFFIC SHAPING ===
CONFIG_NET_SCH_CAKE=y
CONFIG_NET_SCH_HTB=y
CONFIG_NET_SCH_HFSC=y
CONFIG_NET_SCH_FQ=y
CONFIG_NET_SCH_FQ_CODEL=y
CONFIG_NET_SCH_PIE=y
CONFIG_DEFAULT_CAKE=y

# === VLAN SUPPORT ===
CONFIG_8021Q=y
CONFIG_8021Q_MVRP=y
CONFIG_VLAN_8021Q=y
CONFIG_BRIDGE_VLAN_FILTERING=y

# === NETFILTER AND FIREWALL ===
CONFIG_NF_CONNTRACK_ZONES=y
CONFIG_NF_CONNTRACK_EVENTS=y
CONFIG_NF_CONNTRACK_TIMEOUT=y
CONFIG_NF_CONNTRACK_TIMESTAMP=y
CONFIG_NF_NAT=y
CONFIG_NF_NAT_MASQUERADE=y

# Netfilter flow offload for performance
CONFIG_NF_FLOW_TABLE=y
CONFIG_NF_FLOW_TABLE_INET=y
CONFIG_NETFILTER_XT_TARGET_FLOWOFFLOAD=y

# IPv4 NAT and firewall
CONFIG_IP_NF_MANGLE=y
CONFIG_IP_NF_NAT=y
CONFIG_IP_NF_TARGET_MASQUERADE=y
CONFIG_IP_NF_TARGET_NETMAP=y
CONFIG_IP_NF_TARGET_REDIRECT=y

# IPv6 firewall
CONFIG_IP6_NF_MANGLE=y
CONFIG_IP6_NF_NAT=y
CONFIG_IP6_NF_TARGET_MASQUERADE=y

# nftables support
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_NETDEV=y
CONFIG_NFT_NUMGEN=y
CONFIG_NFT_FLOW_OFFLOAD=y
CONFIG_NFT_CONNLIMIT=y
CONFIG_NFT_MASQ=y
CONFIG_NFT_REDIR=y
CONFIG_NFT_NAT=y
CONFIG_NFT_QUEUE=y
CONFIG_NFT_QUOTA=y

# === BATMAN-ADV MESH NETWORKING ===
CONFIG_BATMAN_ADV=y
CONFIG_BATMAN_ADV_BATMAN_V=y
CONFIG_BATMAN_ADV_BLA=y
CONFIG_BATMAN_ADV_DAT=y
CONFIG_BATMAN_ADV_MCAST=y
CONFIG_BATMAN_ADV_NC=y
CONFIG_BATMAN_ADV_TRACING=y

# === CPU AND PERFORMANCE OPTIMIZATIONS ===
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_GOV_ONDEMAND=y

# IRQ balancing and multi-core optimization
CONFIG_IRQ_FORCED_THREADING=y
CONFIG_SMP=y
CONFIG_NR_CPUS=4
CONFIG_RPS=y
CONFIG_RFS_ACCEL=y

# === PACKET PROCESSING OPTIMIZATIONS ===
CONFIG_BPF=y
CONFIG_BPF_JIT=y
CONFIG_BPF_JIT_ALWAYS_ON=y
CONFIG_BPF_SYSCALL=y
CONFIG_NET_CLS_BPF=y
CONFIG_NET_ACT_BPF=y

# Network packet steering
CONFIG_XPS=y

# === WIRELESS 802.11 OPTIMIZATIONS ===
CONFIG_MAC80211_MESH=y
CONFIG_MAC80211_RC_MINSTREL=y
CONFIG_MAC80211_RC_MINSTREL_HT=y
CONFIG_MAC80211_RC_MINSTREL_VHT=y
CONFIG_MAC80211_RC_DEFAULT_MINSTREL=y

# === HARDWARE CRYPTO ACCELERATION FIXED ===
# IPQ4019 QCE (Qualcomm Crypto Engine) - Built-in for stability
CONFIG_CRYPTO_HW=y
CONFIG_CRYPTO_DEV_QCE=y
CONFIG_CRYPTO_DEV_QCE_AEAD=y
CONFIG_CRYPTO_DEV_QCE_SKCIPHER=y
CONFIG_CRYPTO_DEV_QCE_SHA=y

# Essential crypto support - built-in
CONFIG_CRYPTO_CRYPTD=y
CONFIG_CRYPTO_CCM=y
CONFIG_CRYPTO_CMAC=y
CONFIG_CRYPTO_CRC32C=y
CONFIG_CRYPTO_GF128MUL=y
CONFIG_CRYPTO_GHASH=y
CONFIG_CRYPTO_HASH_INFO=y

# Disable software crypto that conflicts with hardware
# CONFIG_CRYPTO_AES_ARM is not set
# CONFIG_CRYPTO_SHA1_ARM is not set
# CONFIG_CRYPTO_SHA256_ARM is not set
# CONFIG_CRYPTO_SHA512_ARM is not set

# === MEMORY MANAGEMENT ===
# Fix zsmalloc configuration
CONFIG_ZSMALLOC=y
# CONFIG_ZSMALLOC_STAT is not set
CONFIG_ZSMALLOC_CHAIN_SIZE=8
# CONFIG_SHUFFLE_PAGE_ALLOCATOR is not set
CONFIG_COMPAT_BRK=y
CONFIG_FLATMEM_MANUAL=y
CONFIG_COMPACTION=y
# CONFIG_PAGE_REPORTING is not set
CONFIG_MIGRATION=y
CONFIG_PCP_BATCH_SCALE_MAX=5
# CONFIG_KSM is not set
CONFIG_DEFAULT_MMAP_MIN_ADDR=4096
CONFIG_CMA=y
# CONFIG_CMA_DEBUGFS is not set
# CONFIG_CMA_SYSFS is not set
CONFIG_CMA_AREAS=8
# CONFIG_IDLE_PAGE_TRACKING is not set
# CONFIG_PERCPU_STATS is not set
# CONFIG_GUP_TEST is not set
# CONFIG_DMAPOOL_TEST is not set
# CONFIG_ANON_VMA_NAME is not set
# CONFIG_LRU_GEN is not set

# === L2TP CONFIGURATION ===
# Fix L2TP configuration to prevent prompts
CONFIG_L2TP=y
# CONFIG_L2TP_DEBUGFS is not set

# === LED AND GPIO SUPPORT ===
CONFIG_LEDS_GPIO=y
CONFIG_LEDS_TRIGGER_TIMER=y
CONFIG_LEDS_TRIGGER_ONESHOT=y
CONFIG_LEDS_TRIGGER_HEARTBEAT=y
CONFIG_LEDS_TRIGGER_GPIO=y
CONFIG_LEDS_TRIGGER_NETDEV=y

# === FILESYSTEM OPTIMIZATIONS ===
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_DECOMP_MULTI_PERCPU=y
CONFIG_SQUASHFS_XATTR=y
CONFIG_SQUASHFS_ZLIB=y
CONFIG_SQUASHFS_LZ4=y
CONFIG_SQUASHFS_LZO=y
CONFIG_SQUASHFS_XZ=y

# JFFS2 for overlay
CONFIG_JFFS2_FS=y
CONFIG_JFFS2_COMPRESSION_OPTIONS=y
CONFIG_JFFS2_LZO=y

# === MTD AND FLASH SUPPORT ===
CONFIG_MTD=y
CONFIG_MTD_CMDLINE_PARTS=y
CONFIG_MTD_SPI_NOR=y
CONFIG_MTD_SPLIT_FIRMWARE=y
CONFIG_MTD_SPLIT_TPLINK_FW=y

# === BRIDGE AND SWITCHING ===
CONFIG_BRIDGE=y
CONFIG_BRIDGE_IGMP_SNOOPING=y
CONFIG_BRIDGE_MRP=y
CONFIG_NET_DSA=y
CONFIG_NET_DSA_TAG_QCA=y

# === TCP OPTIMIZATIONS ===
CONFIG_TCP_CONG_BBR=y
CONFIG_TCP_CONG_CUBIC=y
CONFIG_DEFAULT_BBR=y

# === 802.1X AND RADIUS CLIENT SUPPORT ===
CONFIG_WEXT_CORE=y
CONFIG_WEXT_PRIV=y
CONFIG_CFG80211=y
CONFIG_CFG80211_WEXT=y

# === EXPLICITLY DISABLE UNUSED FEATURES ===
# USB Support - Not used in Deco M4 v3
# CONFIG_USB_SUPPORT is not set

# Audio/Video - Not needed for router
# CONFIG_SOUND is not set
# CONFIG_MEDIA_SUPPORT is not set

# PCIe - Not used in M4 v3
# CONFIG_PCI is not set

# Bluetooth - Not needed
# CONFIG_BT is not set

# Debugging features - disable for size and stability
# CONFIG_DEBUG_INFO is not set
# CONFIG_DEBUG_KERNEL is not set
# CONFIG_KALLSYMS is not set
# CONFIG_PRINTK_TIME is not set
# CONFIG_DYNAMIC_DEBUG is not set
# CONFIG_DEBUG_FS is not set

# === IPQ4019 SPECIFIC OPTIMIZATIONS ===
CONFIG_ARCH_QCOM=y
CONFIG_ARM_QCOM_CPUFREQ_HW=y

# === PERFORMANCE GOVERNOR ===
CONFIG_CPU_FREQ_DEFAULT_GOV_PERFORMANCE=y

# === ESSENTIAL SYSTEM ===
CONFIG_PROC_FS=y
CONFIG_PROC_NET=y
CONFIG_SYSFS=y

# === ADDITIONAL CONFIGS TO PREVENT PROMPTS ===
CONFIG_SCSI=y
# CONFIG_SCSI_PROC_FS is not set
# CONFIG_BLK_DEV_SD is not set
# CONFIG_BLK_DEV_SR is not set
# CONFIG_CHR_DEV_SG is not set
# CONFIG_SCSI_MULTI_LUN is not set
# CONFIG_SCSI_CONSTANTS is not set
# CONFIG_SCSI_SCAN_ASYNC is not set

# Network testing - disable to avoid prompts
# CONFIG_NET_PKTGEN is not set

# Wireless testing - disable
# CONFIG_MAC80211_HWSIM is not set

# ATM - disable entirely
# CONFIG_ATM is not set

# ISDN - disable
# CONFIG_ISDN is not set

# === CRYPTO ALGORITHM SELECTION ===
# Ensure required crypto algorithms are available
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_CBC=y
CONFIG_CRYPTO_CTR=y
CONFIG_CRYPTO_ECB=y
CONFIG_CRYPTO_XTS=y
CONFIG_CRYPTO_CTS=y
CONFIG_CRYPTO_GCM=y
CONFIG_CRYPTO_SEQIV=y
CONFIG_CRYPTO_SHA1=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_SHA512=y
CONFIG_CRYPTO_HMAC=y
CONFIG_CRYPTO_MD5=y
CONFIG_CRYPTO_MICHAEL_MIC=y
CONFIG_CRYPTO_RNG=y
CONFIG_CRYPTO_RNG_DEFAULT=y
CONFIG_CRYPTO_DRBG_MENU=y
CONFIG_CRYPTO_DRBG_HMAC=y
CONFIG_CRYPTO_JITTERENTROPY=y

# === WATCHDOG ===
# CONFIG_WATCHDOG is not set

# === RTC ===
# CONFIG_RTC_CLASS is not set

# === HWMON ===
# CONFIG_HWMON is not set

# === THERMAL ===
CONFIG_THERMAL=y
CONFIG_THERMAL_DEFAULT_GOV_STEP_WISE=y
CONFIG_THERMAL_GOV_STEP_WISE=y

# === REGULATOR ===
CONFIG_REGULATOR=y

# === GPIO ===
CONFIG_GPIOLIB=y
CONFIG_OF_GPIO=y
CONFIG_GPIO_SYSFS=y

# === PINCTRL ===
CONFIG_PINCTRL=y

# === CLOCKS ===
CONFIG_COMMON_CLK=y

# === DMA ===
CONFIG_DMADEVICES=y
