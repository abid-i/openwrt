# Memory Management - CMA Configuration
CONFIG_CMA=y
CONFIG_CMA_DEBUGFS=n
CONFIG_CMA_SYSFS=n
CONFIG_CMA_AREAS=8
# CMA Size Selection - 64MB is optimal for 256MB RAM system
CONFIG_CMA_SIZE_MBYTES=64
CONFIG_CMA_SIZE_SEL_MBYTES=y
# CMA Alignment - 8 is standard for ARM systems
CONFIG_CMA_ALIGNMENT=8
CONFIG_DMA_CMA=y

# Essential Filesystems Only (Space Optimization)
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_XZ=y
CONFIG_JFFS2_FS=y
CONFIG_TMPFS=y
CONFIG_RAMFS=y
# CONFIG_EXT4_FS is not set
# CONFIG_XFS_FS is not set
# CONFIG_BTRFS_FS is not set
# CONFIG_F2FS_FS is not set


# Hardware Crypto Acceleration (IPQ4019 QCE)
CONFIG_CRYPTO_HW=y
CONFIG_CRYPTO_DEV_QCE=y
CONFIG_CRYPTO_DEV_QCE_ENABLE_SKCIPHER=y
CONFIG_CRYPTO_SHA1_ARM_NEON=y
CONFIG_CRYPTO_SHA256_ARM_NEON=y
CONFIG_CRYPTO_AES_ARM_BS=y

# CORRECT Ethernet Configuration for IPQ4019 + QCA8072
# Keep EDMA (this is the correct driver for IPQ4019)
CONFIG_NET_VENDOR_QUALCOMM=y
CONFIG_QCOM_IPQ4019_ESS_EDMA=y
# CONFIG_QCOM_IPQ4019_ESS_EDMA_IPQESS is not set (disable the buggy ipqess)

# QCA PHY Support (for QCA8072)
CONFIG_AT803X_PHY=y
CONFIG_QCA807X_PHY=y
CONFIG_PHYLIB=y
CONFIG_SWPHY=y

# WiFi Performance Optimization
CONFIG_ATH10K=y
CONFIG_ATH10K_AHB=y
# CONFIG_ATH10K_DEBUG is not set
CONFIG_ATH10K_DFS_CERTIFIED=y
CONFIG_ATH10K_SPECTRAL=y
CONFIG_MAC80211_RC_MINSTREL=y
CONFIG_MAC80211_RC_MINSTREL_HT=y
CONFIG_MAC80211_RC_MINSTREL_VHT=y

# MTD and Flash Support
CONFIG_MTD=y
CONFIG_MTD_SPI_NOR=y
CONFIG_MTD_SPLIT=y
CONFIG_MTD_SPLIT_FIT_FW=y
CONFIG_MTD_SPLIT_SQUASHFS_ROOT=y
CONFIG_MTD_CMDLINE_PARTS=y

# DSA Switch Support (IPQ4019 integrated switch)
CONFIG_NET=y
CONFIG_NET_CORE=y
CONFIG_NET_RX_BUSY_POLL=y
CONFIG_NET_SCHED=y
CONFIG_NET_SCH_FQ_CODEL=y
CONFIG_NET_SCH_HTB=y
CONFIG_NET_CLS_U32=y
CONFIG_NET_CLS_FW=y
CONFIG_NET_ACT_POLICE=y
CONFIG_NET_DSA=y
CONFIG_NET_DSA_QCA8K_IPQ4019=y
CONFIG_NET_SWITCHDEV=y

# Batman-adv debugging (prevent prompts)
CONFIG_BATMAN_ADV=y
CONFIG_BATMAN_ADV_BATMAN_V=y
CONFIG_BATMAN_ADV_BLA=y
CONFIG_BATMAN_ADV_DAT=y
CONFIG_BATMAN_ADV_MCAST=y
CONFIG_BATMAN_ADV_NC=y
CONFIG_BATMAN_ADV_DEBUGFS=y
CONFIG_BATMAN_ADV_DEBUG=n

# Memory model settings (prevent prompts)
CONFIG_FLATMEM_MANUAL=y
CONFIG_FLATMEM=y
CONFIG_FLAT_NODE_MEM_MAP=y

# Security hardning 
CONFIG_STACKPROTECTOR=y
CONFIG_ARCH_HAS_ELF_RANDOMIZE=y
CONFIG_DEBUG_BUGVERBOSE=n

# Network optimization
CONFIG_NET_FLOW_LIMIT=y
CONFIG_RPS=y
CONFIG_RFS_ACCEL=y

# XZ compression options
CONFIG_XZ_DEC_ARM=y
CONFIG_XZ_DEC_MICROLZMA=n

# CRC and library settings
CONFIG_CRC32_SLICEBY8=y
CONFIG_RANDOM32_SELFTEST=n

# Disable debugging features
CONFIG_DMA_API_DEBUG=n
CONFIG_DMA_MAP_BENCHMARK=n
CONFIG_SWIOTLB_DYNAMIC=n
CONFIG_DMA_RESTRICTED_POOL=n
CONFIG_NET_PKTGEN=n
CONFIG_NET_DROP_MONITOR=n

# SMP and IRQ Optimization for Mesh Performance  
CONFIG_SMP=y
CONFIG_NR_CPUS=4
CONFIG_GENERIC_IRQ_MIGRATION=y
CONFIG_IRQ_FORCED_THREADING_DEFAULT=y
CONFIG_IRQSTACKS=y


# CPU power management
CONFIG_CPU_IDLE=y
CONFIG_CPU_IDLE_GOV_LADDER=y
CONFIG_CPU_IDLE_GOV_MENU=y
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_DEFAULT_GOV_PERFORMANCE=y
# CONFIG_CPU_FREQ_DEFAULT_GOV_ONDEMAND is not set
CONFIG_ARM_QCOM_CPUFREQ_HW=y

# 802.11s Mesh Support
CONFIG_MAC80211_MESH=y
CONFIG_CFG80211_WEXT=y

# Networking protocols (minimal for mesh)
CONFIG_NET_KEY=n
CONFIG_NET_IPIP=n
CONFIG_NET_IPGRE_DEMUX=n
CONFIG_INET_AH=n
CONFIG_INET_ESP=n
CONFIG_INET_IPCOMP=n

# Network Protocols for Mesh
CONFIG_IP_ADVANCED_ROUTER=y
CONFIG_IP_MULTIPLE_TABLES=y
CONFIG_IP_ROUTE_MULTIPATH=y
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NF_TABLES=y
CONFIG_NFT_REJECT_INET=y

# Multicast for mesh
CONFIG_IP_MROUTE=y
CONFIG_IP_MROUTE_MULTIPLE_TABLES=y
CONFIG_IP_PIMSM_V1=y
CONFIG_IP_PIMSM_V2=y

# VLAN settings
CONFIG_VLAN_8021Q=y
CONFIG_VLAN_8021Q_GVRP=n
CONFIG_VLAN_8021Q_MVRP=n
CONFIG_BRIDGE_VLAN_FILTERING=y
CONFIG_BRIDGE_IGMP_SNOOPING=y
CONFIG_BRIDGE_MLD_SNOOPING=y

# Flow offloading
CONFIG_NF_FLOW_TABLE=y
CONFIG_NF_FLOW_TABLE_INET=y
CONFIG_NETFILTER_XT_TARGET_FLOWOFFLOAD=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_NAT=y

# Disable debug features
CONFIG_LOCK_DEBUGGING_SUPPORT=n
CONFIG_DEBUG_ATOMIC_SLEEP=n
CONFIG_DEBUG_LIST=n
CONFIG_DEBUG_PLIST=n
CONFIG_DEBUG_SG=n
CONFIG_DEBUG_NOTIFIERS=n

# Size Optimization
CONFIG_CC_OPTIMIZE_FOR_SIZE=y
CONFIG_KERNEL_XZ=y
CONFIG_SLUB=y
CONFIG_SLAB=n
CONFIG_SLUB_DEBUG=n


