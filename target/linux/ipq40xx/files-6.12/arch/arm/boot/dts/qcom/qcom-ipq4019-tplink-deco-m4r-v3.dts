/dts-v1/;

#include "qcom-ipq4019.dtsi"
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include <dt-bindings/leds/common.h>
#include <dt-bindings/soc/qcom,tcsr.h>

/ {
	model = "TP-Link Deco M4R v3";
	compatible = "tplink,deco-m4r-v3", "qcom,ipq4019";

	memory {
		device_type = "memory";
		reg = <0x80000000 0x10000000>; // 256MB RAM (M15T2G16128A)
	};

	chosen {
		// Performance optimizations for mesh networking
		bootargs-append = " rcu_nocbs=0-3 isolcpus=3 irqaffinity=0-2 cgroup_disable=memory";
	};

	aliases {
		led-boot = &led_blue;
		led-failsafe = &led_red;
		led-running = &led_green;
		led-upgrade = &led_red;
		label-mac-device = &swport4;
		serial0 = &blsp1_uart1;
	};

	soc {
		// Optimized TCSR configurations for mesh performance
		tcsr@194b000 {
			compatible = "qcom,tcsr";
			reg = <0x194b000 0x100>;
			qcom,usb-hsphy-mode-select = <TCSR_USB_HSPHY_HOST_MODE>;
			status = "okay";
		};

		tcsr@1949000 {
			compatible = "qcom,tcsr";
			reg = <0x1949000 0x100>;
			qcom,wifi_glb_cfg = <TCSR_WIFI_GLB_CFG>;
		};

		tcsr@1957000 {
			compatible = "qcom,tcsr";
			reg = <0x1957000 0x100>;
			qcom,wifi_noc_memtype_m0_m2 = <TCSR_WIFI_NOC_MEMTYPE_M0_M2>;
		};

		ess_tcsr@1953000 {
			compatible = "qcom,tcsr";
			reg = <0x1953000 0x1000>;
			qcom,ess-interface-select = <TCSR_ESS_PSGMII>;
		};
	};

	keys {
		compatible = "gpio-keys";

		reset {
			label = "reset";
			gpios = <&tlmm 18 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_RESTART>;
		};
	};

	leds {
		compatible = "gpio-leds";

		led_red: led-0 {
			label = "rgb:red";
			gpios = <&tlmm 36 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_RED>;
			function = LED_FUNCTION_FAULT;
		};

		led_green: led-1 {
			label = "rgb:green";
			gpios = <&tlmm 37 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_POWER;
		};

		led_blue: led-2 {
			label = "rgb:blue";
			gpios = <&tlmm 38 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_BLUE>;
			function = LED_FUNCTION_BOOT;
		};
	};
};

&tlmm {
	serial_pins: serial_pinmux {
		mux {
			pins = "gpio16", "gpio17";
			function = "blsp_uart0";
			bias-disable;
		};
	};

	spi_0_pins: spi_0_pinmux {
		pin {
			function = "blsp_spi0";
			pins = "gpio12", "gpio13", "gpio14", "gpio15";
			drive-strength = <12>;
			bias-disable;
		};
	};

	mdio_pins: mdio_pinmux {
		mux_1 {
			pins = "gpio6";
			function = "mdio";
			bias-pull-up;
		};
		mux_2 {
			pins = "gpio7";
			function = "mdc";
			bias-pull-up;
		};
	};

	// Optimized WiFi GPIO configuration for mesh performance
	wifi_pins: wifi_pinmux {
		pinmux_1 {
			pins = "gpio37";
			function = "gpio";
			drive-strength = <8>; // Increased for stability
			bias-pull-up;
			output-high;
		};
		pinmux_2 {
			pins = "gpio42";
			function = "gpio";
			drive-strength = <8>;
			bias-pull-up;
			output-high;
		};
		pinmux_3 {
			pins = "gpio43";
			function = "gpio";
			drive-strength = <8>;
			bias-pull-up;
		};
	};
};

&blsp_dma {
	status = "okay";
};

&blsp1_uart1 {
	pinctrl-0 = <&serial_pins>;
	pinctrl-names = "default";
	status = "okay";
};

&blsp1_spi1 {
	pinctrl-0 = <&spi_0_pins>;
	pinctrl-names = "default";
	status = "okay";
	cs-gpios = <&tlmm 12 GPIO_ACTIVE_HIGH>;

	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <50000000>; // Optimized for performance

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			// Boot and system partitions (read-only)
			partition@0 {
				label = "SBL1";
				reg = <0x000000 0x030000>;
				read-only;
			};

			partition@30000 {
				label = "BOOTCONFIG";
				reg = <0x030000 0x010000>;
				read-only;
			};

			partition@40000 {
				label = "MIBIB";
				reg = <0x040000 0x010000>;
				read-only;
			};

			partition@50000 {
				label = "BOOTCONFIG1";
				reg = <0x050000 0x010000>;
				read-only;
			};

			partition@60000 {
				label = "QSEE";
				reg = <0x060000 0x060000>;
				read-only;
			};

			partition@c0000 {
				label = "CDT";
				reg = <0x0c0000 0x010000>;
				read-only;
			};

			partition@d0000 {
				label = "DDRPARAMS";
				reg = <0x0d0000 0x010000>;
				read-only;
			};

			partition@e0000 {
				label = "uboot-env";
				reg = <0x0e0000 0x010000>;
			};

			partition@f0000 {
				label = "u-boot";
				reg = <0x0f0000 0x080000>;
				read-only;
			};

			art: partition@170000 {
				label = "art";
				reg = <0x170000 0x010000>;
				read-only;

				nvmem-layout {
					compatible = "fixed-layout";
					#address-cells = <1>;
					#size-cells = <1>;

					macaddr_art_0: macaddr@0 {
						compatible = "mac-base";
						reg = <0x0 0x6>;
						#nvmem-cell-cells = <1>;
					};

					// WiFi calibration data for IPQ4019 dual-band radio
					precal_art_1000: precal@1000 {
						reg = <0x1000 0x2f20>;
					};

					precal_art_5000: precal@5000 {
						reg = <0x5000 0x2f20>;
					};
				};
			};

			// Configuration partitions
			partition@180000 {
				label = "OPAQUE";
				reg = <0x180000 0x0c0000>;
				read-only;
			};

			// SLOT 0 - Stock firmware (kept for recovery)
			partition@240000 {
				label = "firmware-slot0";
				reg = <0x240000 0xd20000>;
				read-only;
			};

			// Configuration and metadata
			partition@f60000 {
				label = "stock-config";
				reg = <0xf60000 0x060000>;
				read-only;
			};

			// SLOT 1 - OpenWrt firmware (15.375MB combined space)
			// MTD splitter automatically separates kernel and rootfs
			partition@1020000 {
				label = "firmware";
				reg = <0x1020000 0xf60000>;
				compatible = "tplink,firmware";
			};

			// Slot 1 metadata partitions
			partition@1f80000 {
				label = "config-data";
				reg = <0x1f80000 0x080000>;
			};
		};
	};
};

// Hardware crypto acceleration for mesh performance
&crypto {
	status = "okay";
};

&cryptobam {
	status = "okay";
};

&prng {
	status = "okay";
};

// Network configuration optimized for mesh and VLAN switching
&mdio {
	status = "okay";
	pinctrl-0 = <&mdio_pins>;
	pinctrl-names = "default";
	reset-gpios = <&tlmm 47 GPIO_ACTIVE_LOW>;
	reset-delay-us = <2000>; // Increased for stability
};

&watchdog {
	status = "okay";
};

&gmac {
	status = "okay";
};

&switch {
	status = "okay";
};

&swport4 {
	status = "okay";
	label = "lan";
	nvmem-cell-names = "mac-address";
	nvmem-cells = <&macaddr_art_0 0>;
};

&swport5 {
	status = "okay";
	label = "wan";
	nvmem-cell-names = "mac-address";
	nvmem-cells = <&macaddr_art_0 1>;
};

// WiFi configuration optimized for mesh performance and RADIUS VLAN mapping
&wifi0 {
	status = "okay";
	pinctrl-0 = <&wifi_pins>;
	pinctrl-names = "default";
	nvmem-cell-names = "pre-calibration", "mac-address";
	nvmem-cells = <&precal_art_1000>, <&macaddr_art_0 2>;
	qcom,ath10k-calibration-variant = "tplink_deco-m4r-v3";
};

&wifi1 {
	status = "okay";
	nvmem-cell-names = "pre-calibration", "mac-address";
	nvmem-cells = <&precal_art_5000>, <&macaddr_art_0 3>;
	qcom,ath10k-calibration-variant = "tplink_deco-m4r-v3";
};

// Disable unused USB interfaces for power savings and reduced complexity
&usb2 {
	status = "disabled";
};

&usb2_hs_phy {
	status = "disabled";
};

&usb3 {
	status = "disabled";
};

&usb3_hs_phy {
	status = "disabled";
};

&usb3_ss_phy {
	status = "disabled";
};

