/dts-v1/;

#include "qcom-ipq4019.dtsi"
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include <dt-bindings/leds/common.h>
#include <dt-bindings/soc/qcom,tcsr.h>

/ {
	model = "TP-Link Deco M4R v3";
	compatible = "tplink,deco-m4r-v3", "qcom,ipq4019";

	aliases {
		led-boot = &led_power_green;
		led-failsafe = &led_power_red;
		led-running = &led_power_green;
		led-upgrade = &led_power_blue;
		serial0 = &blsp1_uart1;
		ethernet0 = &gmac0;
		ethernet1 = &gmac1;
		label-mac-device = &gmac0;
	};

	chosen {
		stdout-path = "serial0:115200n8";
		bootargs-append = " swiotlb=1 coherent_pool=2M";
	};

	memory {
		device_type = "memory";
		reg = <0x80000000 0x10000000>; /* 256MB DDR3L */
	};

	keys {
		compatible = "gpio-keys";
		pinctrl-0 = <&button_pins>;
		pinctrl-names = "default";

		reset {
			label = "reset";
			gpios = <&tlmm 18 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_RESTART>;
			debounce-interval = <60>;
		};
	};

	leds {
		compatible = "gpio-leds";
		pinctrl-0 = <&led_pins>;
		pinctrl-names = "default";

		led_power_red: power_red {
			color = <LED_COLOR_ID_RED>;
      label = "red:status";
      function = LED_FUNCTION_STATUS;
			gpios = <&tlmm 28 GPIO_ACTIVE_LOW>;
		};

		led_power_green: power_green {
			label = "green:power";
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_POWER;
			gpios = <&tlmm 32 GPIO_ACTIVE_LOW>;
		};

		led_power_blue: power_blue {
			label = "blue:indicator"; 
      color = <LED_COLOR_ID_BLUE>;
			function = LED_FUNCTION_INDICATOR;
			gpios = <&tlmm 35 GPIO_ACTIVE_LOW>;
		};
	};

	soc {
		rng@22000 {
			status = "okay";
		};

		crypto@8e3a000 {
			status = "okay";
		};

		watchdog@b017000 {
			status = "okay";
		};

		// TCSR configurations - critical for IPQ4019 performance
		tcsr@194b000 {
			compatible = "qcom,tcsr";
			reg = <0x194b000 0x100>;
			qcom,usb-hsphy-mode-select = <TCSR_USB_HSPHY_HOST_MODE>;
			status = "okay";
		};

		// WiFi global configuration - optimized for mesh performance
		tcsr@1949000 {
			compatible = "qcom,tcsr";
			reg = <0x1949000 0x100>;
			qcom,wifi_glb_cfg = <TCSR_WIFI_GLB_CFG>;
		};

		// WiFi NOC memory type - critical for performance
		tcsr@1957000 {
			compatible = "qcom,tcsr";
			reg = <0x1957000 0x100>;
			qcom,wifi_noc_memtype_m0_m2 = <TCSR_WIFI_NOC_MEMTYPE_M0_M2>;
		};

		// ESS interface select - enables PSGMII for gigabit ethernet
		ess_tcsr@1953000 {
			compatible = "qcom,tcsr";
			reg = <0x1953000 0x1000>;
			qcom,ess-interface-select = <TCSR_ESS_PSGMII>;
		};

		// EDMA ethernet controller
		edma@c080000 {
			status = "okay";
		};

		// ESS switch
		ess-switch@c000000 {
			status = "okay";
		};

		// MDIO bus
		mdio@90000 {
			status = "okay";
			pinctrl-0 = <&mdio_pins>;
			pinctrl-names = "default";
			reset-gpios = <&tlmm 47 GPIO_ACTIVE_LOW>;
			reset-delay-us = <2000>;

			ethphy3: ethernet-phy@3 {
				reg = <3>;
			};

			ethphy4: ethernet-phy@4 {
				reg = <4>;
			};
		};
	};
};

&tlmm {
	button_pins: button_pinmux {
		mux {
			pins = "gpio18";
			function = "gpio";
			bias-pull-up;
		};
	};

	led_pins: led_pinmux {
		mux {
			pins = "gpio28", "gpio32", "gpio35";
			function = "gpio";
			bias-pull-down;
		};
	};

	serial_1_pins: serial1_pinmux {
		mux {
			pins = "gpio8", "gpio9";
			function = "blsp_uart1";
			bias-disable;
		};
	};

	spi_0_pins: spi_0_pinmux {
		pin {
			function = "blsp_spi0";
			pins = "gpio13", "gpio14", "gpio15";
			drive-strength = <12>;
			bias-disable;
		};

		pin_cs {
			function = "gpio";
			pins = "gpio12";
			drive-strength = <2>;
			bias-disable;
			output-high;
		};
	};

	wifi_0_pins: wifi1_pinmux {
		mux_1 {
			pins = "gpio37";
			output-high;
			function = "wcss0_dbg16";
			bias-pull-up;
			drive-strength = <6>;
		};

		mux_2 {
			pins = "gpio43";
			function = "wifi_wci1";
			bias-pull-up;
			drive-strength = <6>;
		};

		mux_3 {
			pins = "gpio42";
			output-high;
			function = "gpio";
			bias-pull-up;
			drive-strength = <6>;
		};
	};

	mdio_pins: mdio_pinmux {
		mux {
			pins = "gpio6", "gpio7";
			function = "mdio";
			bias-pull-up;
		};
	};
};

&blsp1_spi1 {
	status = "okay";
	cs-gpios = <&tlmm 12 GPIO_ACTIVE_HIGH>;
	pinctrl-0 = <&spi_0_pins>;
	pinctrl-names = "default";

	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <24000000>;

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			partition@0 {
				label = "SBL1";
				reg = <0x000000 0x030000>;
				read-only;
			};

			partition@30000 {
				label = "BOOTCONFIG";
				reg = <0x030000 0x010000>;
				read-only;
			};

			partition@40000 {
				label = "MIBIB";
				reg = <0x040000 0x010000>;
				read-only;
			};

			partition@50000 {
				label = "BOOTCONFIG1";
				reg = <0x050000 0x010000>;
				read-only;
			};

			partition@60000 {
				label = "QSEE";
				reg = <0x060000 0x060000>;
				read-only;
			};

			partition@c0000 {
				label = "CDT";
				reg = <0x0c0000 0x010000>;
				read-only;
			};

			partition@d0000 {
				label = "DDRPARAMS";
				reg = <0x0d0000 0x010000>;
				read-only;
			};

			partition@e0000 {
				label = "uboot-env";
				reg = <0x0e0000 0x010000>;
			};

			partition@f0000 {
				label = "u-boot";
				reg = <0x0f0000 0x080000>;
				read-only;
			};

			partition@170000 {
				label = "art";
				reg = <0x170000 0x010000>;
				read-only;

				nvmem-layout {
					compatible = "fixed-layout";
					#address-cells = <1>;
					#size-cells = <1>;

					macaddr_art_0: macaddr@0 {
						compatible = "mac-base";
						reg = <0x0 0x6>;
						#nvmem-cell-cells = <1>;
					};

					macaddr_art_6: macaddr@6 {
						reg = <0x6 0x6>;
					};

					precal_art_1000: precal@1000 {
						reg = <0x1000 0x2f20>;
					};

					precal_art_5000: precal@5000 {
						reg = <0x5000 0x2f20>;
					};
				};
			};

			/* Configuration partitions - preserve stock layout */
			partition@180000 {
				label = "default-mac";
				reg = <0x180000 0x001000>;
				read-only;
			};

			partition@181000 {
				label = "device-id";
				reg = <0x181000 0x001000>;
				read-only;
			};

			partition@182000 {
				label = "product-info";
				reg = <0x182000 0x006000>;
				read-only;
			};

			partition@190000 {
				label = "support-list";
				reg = <0x190000 0x010000>;
				read-only;
			};

			partition@200000 {
				label = "user-config";
				reg = <0x200000 0x010000>;
			};

			partition@210000 {
				label = "device-config";
				reg = <0x210000 0x010000>;
			};

			partition@220000 {
				label = "group-info";
				reg = <0x220000 0x010000>;
			};

			partition@230000 {
				label = "partition-table@0";
				reg = <0x230000 0x002000>;
				read-only;
			};

			/* SLOT 0 - Keep separate for stock firmware recovery */
			partition@240000 {
				label = "os-image@0";
				reg = <0x240000 0x320000>;
				read-only;
			};

			partition@560000 {
				label = "file-system@0";
				reg = <0x560000 0xa00000>;
				read-only;
			};

			partition@f60000 {
				label = "soft-version@0";
				reg = <0xf60000 0x010000>;
				read-only;
			};

			partition@f70000 {
				label = "profile@0";
				reg = <0xf70000 0x010000>;
				read-only;
			};

			partition@f80000 {
				label = "default-config@0";
				reg = <0xf80000 0x010000>;
				read-only;
			};

			partition@f90000 {
				label = "partition-table@1";
				reg = <0xf90000 0x002000>;
				read-only;
			};

			partition@fa0000 {
				label = "fs-uboot@1";
				reg = <0xfa0000 0x080000>;
				read-only;
			};

			/* SLOT 1 - Combined firmware partition for OpenWrt */
			/* MTD splitter will automatically separate kernel/rootfs */
			partition@1020000 {
				label = "firmware";
				reg = <0x1020000 0xfa0000>;
				compatible = "tplink,firmware";
			};

			/* Slot 1 metadata partitions */
			partition@1fc0000 {
				label = "soft-version@1";
				reg = <0x1fc0000 0x010000>;
			};

			partition@1fd0000 {
				label = "profile@1";
				reg = <0x1fd0000 0x010000>;
			};

			partition@1fe0000 {
				label = "default-config@1";
				reg = <0x1fe0000 0x010000>;
			};

			partition@1ff0000 {
				label = "url-sig";
				reg = <0x1ff0000 0x010000>;
			};
		};
	};
};

&blsp1_uart1 {
	pinctrl-0 = <&serial_1_pins>;
	pinctrl-names = "default";
	status = "okay";
};

&cryptobam {
	status = "okay";
};

&blsp_dma {
	status = "okay";
};

&crypto {
	status = "okay";
};

&prng {
	status = "okay";
};

/* Dual Ethernet Configuration via Linux 6.12 DSA */
&gmac0 {
	status = "okay";
	phy-mode = "psgmii";
	qcom,id = <0>;

	nvmem-cell-names = "mac-address";
	nvmem-cells = <&macaddr_art_0 0>;

	fixed-link {
		speed = <1000>;
		full-duplex;
	};
};

&gmac1 {
	status = "okay";
	phy-mode = "psgmii";
	qcom,id = <1>;

	nvmem-cell-names = "mac-address";
	nvmem-cells = <&macaddr_art_0 1>;

	fixed-link {
		speed = <1000>;
		full-duplex;
	};
};

&switch {
	status = "okay";
	
	ports {
		#address-cells = <1>;
		#size-cells = <0>;
		
		port@0 {
			reg = <0>;
			label = "cpu";
			ethernet = <&gmac0>;
			phy-mode = "psgmii";
			
			fixed-link {
				speed = <1000>;
				full-duplex;
			};
		};

		/* QCA8072 dual ports mapped to switch ports 3,4 */
		port@3 {
			reg = <3>;
			label = "lan1";
			phy-handle = <&ethphy3>;
		};

		port@4 {
			reg = <4>;
			label = "lan2";
			phy-handle = <&ethphy4>;
		};
	};
	
	mdio {
		#address-cells = <1>;
		#size-cells = <0>;
		
		phy3: phy@3 {
			reg = <3>;
		};
		
		phy4: phy@4 {
			reg = <4>;
		};
	};
};

&wifi0 {
	status = "okay";
	nvmem-cell-names = "pre-calibration", "mac-address";
	nvmem-cells = <&precal_art_1000>, <&macaddr_art_0 2>;
	qcom,ath10k-calibration-variant = "tplink-deco-m4r-v3";

	pinctrl-0 = <&wifi_0_pins>;
	pinctrl-names = "default";
	btcoex_support = <1>;
	wlan_prio_gpio = <42>;
};

&wifi1 {
	status = "okay";
	nvmem-cell-names = "pre-calibration", "mac-address";
	nvmem-cells = <&precal_art_5000>, <&macaddr_art_0 3>;
	qcom,ath10k-calibration-variant = "tplink-deco-m4r-v3";
	btcoex_support = <0>;
};

&usb3_hs_phy {
	status = "disabled";
};

&usb3_ss_phy {
	status = "disabled";
};

&usb3 {
	status = "disabled";
};

&usb2_hs_phy {
	status = "disabled";
};

&usb2 {
	status = "disabled";
};

