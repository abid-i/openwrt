#include "qcom-ipq4019.dtsi"
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include <dt-bindings/leds/common.h>
#include <dt-bindings/soc/qcom,tcsr.h>

/ {
	model = "TP-Link Deco M4R v3";
	compatible = "tp-link,deco-m4r-v3", "qcom,ipq4019";

	chosen {
		bootargs-append = " clk_ignore_unused";
	};

	aliases {
		led-boot = &led_status_blue;
		led-failsafe = &led_status_red;
		led-running = &led_status_white;
		led-upgrade = &led_status_blue;
		serial0 = &blsp1_uart1;
		ethernet0 = "/soc/edma@c080000/gmac0";
		ethernet1 = "/soc/edma@c080000/gmac1";
	};

	memory {
		device_type = "memory";
		reg = <0x80000000 0x10000000>; /* 256MB */
	};

	soc {
		rng@22000 {
			status = "okay";
		};

		mdio@90000 {
			status = "okay";
			pinctrl-0 = <&mdio_pins>;
			pinctrl-names = "default";
			reset-gpios = <&tlmm 47 GPIO_ACTIVE_LOW>;
			reset-delay-us = <1000>;
		};

		ess-psgmii@98000 {
			status = "okay";
		};

		tcsr@1949000 {
			compatible = "qcom,tcsr";
			reg = <0x1949000 0x100>;
			qcom,wifi_glb_cfg = <TCSR_WIFI_GLB_CFG>;
		};

		tcsr@194b000 {
			compatible = "qcom,tcsr";
			reg = <0x194b000 0x100>;
			qcom,usb-hsphy-mode-select = <TCSR_USB_HSPHY_HOST_MODE>;
			status = "okay";
		};

		ess_tcsr@1953000 {
			compatible = "qcom,tcsr";
			reg = <0x1953000 0x1000>;
			qcom,ess-interface-select = <TCSR_ESS_PSGMII>;
		};

		tcsr@1957000 {
			compatible = "qcom,tcsr";
			reg = <0x1957000 0x100>;
			qcom,wifi_noc_memtype_m0_m2 = <TCSR_WIFI_NOC_MEMTYPE_M0_M2>;
		};

		usb2@60000 {
			status = "okay";

			dwc3@6000000 {
				#address-cells = <1>;
				#size-cells = <0>;
			};
		};

		usb3@8af8800 {
			status = "okay";

			dwc3@8a00000 {
				#address-cells = <1>;
				#size-cells = <0>;
			};
		};

		crypto@8e3a000 {
			status = "okay";
		};

		watchdog@b017000 {
			status = "okay";
		};

		ess-switch@c000000 {
			status = "okay";
		};

		edma@c080000 {
			status = "okay";
		};
	};

	keys {
		compatible = "gpio-keys";

		reset {
			label = "reset";
			gpios = <&tlmm 63 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_RESTART>;
		};
	};

	leds {
		compatible = "gpio-leds";

		led_status_red: status_red {
			function = LED_FUNCTION_STATUS;
			color = <LED_COLOR_ID_RED>;
			gpios = <&tlmm 36 GPIO_ACTIVE_LOW>;
		};

		led_status_green: status_green {
			function = LED_FUNCTION_STATUS;
			color = <LED_COLOR_ID_GREEN>;
			gpios = <&tlmm 37 GPIO_ACTIVE_LOW>;
		};

		led_status_blue: status_blue {
			function = LED_FUNCTION_STATUS;
			color = <LED_COLOR_ID_BLUE>;
			gpios = <&tlmm 38 GPIO_ACTIVE_LOW>;
		};

		led_status_white: status_white {
			function = LED_FUNCTION_STATUS;
			color = <LED_COLOR_ID_WHITE>;
			gpios = <&tlmm 36 GPIO_ACTIVE_LOW>, <&tlmm 37 GPIO_ACTIVE_LOW>, <&tlmm 38 GPIO_ACTIVE_LOW>;
		};
	};
};

&tlmm {
	serial_pins: serial_pinmux {
		mux {
			pins = "gpio16", "gpio17";
			function = "blsp_uart0";
			bias-disable;
		};
	};

	spi_0_pins: spi_0_pinmux {
		pin {
			function = "blsp_spi0";
			pins = "gpio12", "gpio13", "gpio14", "gpio15";
			drive-strength = <12>;
			bias-disable;
		};
	};

	mdio_pins: mdio_pinmux {
		mux_1 {
			pins = "gpio6";
			function = "mdio";
			bias-pull-up;
		};
		mux_2 {
			pins = "gpio7";
			function = "mdc";
			bias-pull-up;
		};
	};
};

&blsp_dma {
	status = "okay";
};

&blsp1_spi1 {
	pinctrl-0 = <&spi_0_pins>;
	pinctrl-names = "default";
	status = "okay";
	cs-gpios = <&tlmm 12 GPIO_ACTIVE_HIGH>;

	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <24000000>;

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			partition@0 {
				label = "SBL1";
				reg = <0x000000 0x030000>;
				read-only;
			};

			partition@30000 {
				label = "boot-config_0";
				reg = <0x030000 0x010000>;
				read-only;
			};

			partition@40000 {
				label = "MIBIB";
				reg = <0x040000 0x010000>;
				read-only;
			};

			partition@50000 {
				label = "boot-config_1";
				reg = <0x050000 0x010000>;
				read-only;
			};

			partition@60000 {
				label = "QSEE";
				reg = <0x060000 0x060000>;
				read-only;
			};

			partition@c0000 {
				label = "CDT";
				reg = <0x0c0000 0x010000>;
				read-only;
			};

			partition@d0000 {
				label = "DDRPARAMS";
				reg = <0x0d0000 0x010000>;
				read-only;
			};

			partition@e0000 {
				label = "uboot-env";
				reg = <0x0e0000 0x010000>;
			};

			partition@f0000 {
				label = "fs-uboot@0";
				reg = <0x0f0000 0x080000>;
				read-only;
			};

			art: partition@170000 {
				label = "radio";
				reg = <0x170000 0x010000>;
				read-only;
			};

			partition@180000 {
				label = "default-mac";
				reg = <0x180000 0x001000>;
				read-only;
			};

			partition@182000 {
				label = "device-id";
				reg = <0x182000 0x001000>;
				read-only;
			};

			partition@183000 {
				label = "product-info";
				reg = <0x183000 0x005000>;
				read-only;
			};

			partition@190000 {
				label = "support-list";
				reg = <0x190000 0x010000>;
				read-only;
			};

			partition@200000 {
				label = "user-config";
				reg = <0x200000 0x010000>;
			};

			partition@210000 {
				label = "device-config";
				reg = <0x210000 0x010000>;
			};

			partition@220000 {
				label = "group-info";
				reg = <0x220000 0x010000>;
			};

			partition@230000 {
				label = "partition-table@0";
				reg = <0x230000 0x002000>;
				read-only;
			};

			partition@240000 {
				label = "os-image@0";
				reg = <0x240000 0x320000>;
			};

			partition@560000 {
				label = "file-system@0";
				reg = <0x560000 0xa00000>;
			};

			partition@f60000 {
				label = "soft-version@0";
				reg = <0xf60000 0x010000>;
			};

			partition@f70000 {
				label = "profile@0";
				reg = <0xf70000 0x010000>;
			};

			partition@f80000 {
				label = "default-config@0";
				reg = <0xf80000 0x010000>;
				read-only;
			};

			partition@f90000 {
				label = "partition-table@1";
				reg = <0xf90000 0x002000>;
				read-only;
			};

			partition@fa0000 {
				label = "fs-uboot@1";
				reg = <0xfa0000 0x080000>;
				read-only;
			};

			partition@1020000 {
				label = "os-image@1";
				reg = <0x1020000 0x320000>;
			};

			partition@1340000 {
				label = "file-system@1";
				reg = <0x1340000 0xc40000>;
			};

			partition@1fc0000 {
				label = "soft-version@1";
				reg = <0x1fc0000 0x010000>;
			};

			partition@1fd0000 {
				label = "profile@1";
				reg = <0x1fd0000 0x010000>;
			};

			partition@1fe0000 {
				label = "default-config@1";
				reg = <0x1fe0000 0x010000>;
				read-only;
			};

			partition@1ff0000 {
				label = "url-sig";
				reg = <0x1ff0000 0x010000>;
				read-only;
			};
		};
	};
};

&blsp1_uart1 {
	pinctrl-0 = <&serial_pins>;
	pinctrl-names = "default";
	status = "okay";
};

&gmac {
	status = "okay";
};

&switch {
	status = "okay";
};

&swport1 {
	status = "okay";
	label = "wan";
};

&swport2 {
	status = "okay";
	label = "lan";
};

&swport3 {
	status = "disabled";
};

&swport4 {
	status = "disabled";
};

&swport5 {
	status = "okay";
};

&wifi0 {
	status = "okay";
	nvmem-cell-names = "pre-calibration", "mac-address";
	nvmem-cells = <&precal_art_1000>, <&macaddr_art_0>;
	qcom,ath10k-calibration-variant = "tplink_deco-m4r-v3";
};

&wifi1 {
	status = "okay";
	nvmem-cell-names = "pre-calibration", "mac-address";
	nvmem-cells = <&precal_art_5000>, <&macaddr_art_0>;
	qcom,ath10k-calibration-variant = "tplink_deco-m4r-v3";
};

&art {
	nvmem-layout {
		compatible = "fixed-layout";
		#address-cells = <1>;
		#size-cells = <1>;

		macaddr_art_0: macaddr@0 {
			compatible = "mac-base";
			reg = <0x0 0x6>;
			#nvmem-cell-cells = <1>;
		};

		precal_art_1000: precal@1000 {
			reg = <0x1000 0x2f20>;
		};

		precal_art_5000: precal@5000 {
			reg = <0x5000 0x2f20>;
		};
	};
};

